<idea-plugin>
    <id>com.deeptek.ai.idea</id>
    <name>CodeSense AI</name>
    <vendor email="chenpmmc@gmail.com" url="https://github.com/chenpblog/">chenp</vendor>

    <description><![CDATA[
    <p>CodeSense AI is an intelligent code assistant plugin for IntelliJ IDEA, powered by large language models.</p>
    <h2>CodeSense AI — 代码感知 AI 助手</h2>
    <p>IntelliJ IDEA 的智能代码助手插件，提供以下能力：</p>
    <ul>
        <li><b>Code Review</b> — AI-powered code review based on Git Diff / 基于 Git Diff 的 AI 代码审查</li>
        <li><b>Impact Analysis</b> — Automatically analyze call chains and impact scope of code changes / 自动分析代码修改的调用链和影响范围</li>
        <li><b>Agent Execution</b> — AI autonomously uses tools to complete complex tasks / AI 自主使用工具完成复杂任务</li>
        <li><b>Multi-Model Support</b> — MiniMax, GLM, DeepSeek, Qwen and more / 支持 MiniMax、GLM、DeepSeek、通义千问等</li>
    </ul>
    ]]></description>

    <!-- Platform dependencies -->
    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>
    <depends>com.intellij.java</depends>
    <depends optional="true" config-file="kotlin-features.xml">org.jetbrains.kotlin</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Chat ToolWindow (右侧侧边栏) -->
        <toolWindow id="CodeSense AI"
                    anchor="right"
                    factoryClass="com.deeptek.ai.idea.ui.chat.ChatToolWindowFactory"
                    icon="/icons/codesense.svg"/>

        <!-- Settings 页面 -->
        <applicationConfigurable
            parentId="tools"
            instance="com.deeptek.ai.idea.settings.CodeSenseSettingsConfigurable"
            id="com.deeptek.ai.idea.settings"
            displayName="CodeSense AI"/>

        <!-- 持久化存储服务 -->
        <applicationService
            serviceImplementation="com.deeptek.ai.idea.settings.CodeSenseSettings"/>

        <!-- Project-level services -->
        <projectService
            serviceImplementation="com.deeptek.ai.idea.git.GitDiffService"/>
        <projectService
            serviceImplementation="com.deeptek.ai.idea.analysis.CallHierarchyAnalyzer"/>
        <projectService
            serviceImplementation="com.deeptek.ai.idea.review.CodeReviewService"/>
    </extensions>

    <actions>
        <!-- 编辑器右键菜单 -->
        <group id="CodeSense.EditorPopupMenu" text="CodeSense AI" popup="true">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <action id="CodeSense.ExplainCode"
                    class="com.deeptek.ai.idea.actions.ExplainCodeAction"
                    text="解释代码"
                    description="使用 AI 解释选中的代码"/>
            <action id="CodeSense.AnalyzeImpact"
                    class="com.deeptek.ai.idea.actions.AnalyzeImpactAction"
                    text="分析影响范围"
                    description="分析当前方法的调用链和影响范围"/>
            <action id="CodeSense.AskCodeSense"
                    class="com.deeptek.ai.idea.actions.AskCodeSenseAction"
                    text="咨询 AI"
                    description="带上选中代码打开 AI 对话"/>
        </group>

        <!-- VCS 菜单：审查当前分支与主干 (暂时隐藏) -->
        <!--
        <action id="CodeSense.ReviewGitChanges"
                class="com.deeptek.ai.idea.actions.ReviewGitChangesAction"
                text="审查当前分支与主干"
                description="对比当前分支与主干分支的差异，调用大模型进行代码审查">
            <add-to-group group-id="VcsGroups" anchor="last"/>
        </action>
        -->

        <!-- VCS 菜单：分析变更影响范围 -->
        <action id="CodeSense.AnalyzeBranchImpact"
                class="com.deeptek.ai.idea.actions.AnalyzeBranchImpactAction"
                text="分析变更影响范围"
                description="对比分支差异，自动分析所有变更方法的调用链和影响范围">
            <add-to-group group-id="VcsGroups" anchor="last"/>
        </action>

        <!-- Tools 菜单 -->
        <group id="CodeSense.ToolsMenu" text="CodeSense AI" popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <reference ref="CodeSense.AnalyzeBranchImpact"/>
            <!-- <reference ref="CodeSense.ReviewGitChanges"/> -->
        </group>
    </actions>
</idea-plugin>
